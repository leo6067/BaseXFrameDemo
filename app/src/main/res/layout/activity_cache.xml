<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.file.CacheActivity">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/root_bg">


        <include
            android:id="@+id/scanLay"
            layout="@layout/merge_clear_scan" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/fileLin"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">


            <ImageView
                android:id="@+id/topView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_150"
                android:background="@drawable/root_bg_radius"
                app:layout_constraintTop_toTopOf="parent" />


            <TextView
                android:id="@+id/ratioTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_35"
                android:text="75"
                android:textColor="#ffffffff"
                android:textSize="@dimen/sp_40"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />


            <TextView
                android:id="@+id/memoryTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dp_11"
                android:text="8.0 GB/12 GB"
                android:textColor="#ffffffff"
                android:textSize="@dimen/sp_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ratioTV" />


            <ExpandableListView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dp_35"
                android:layout_marginBottom="@dimen/dp_15"
                android:childIndicator="@null"
                android:groupIndicator="@null"
                android:scrollbars="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/topView" />




            <com.ruffian.library.widget.RTextView
                android:id="@+id/clearTV"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_52"
                android:layout_marginHorizontal="@dimen/dp_40"
                android:layout_marginTop="@dimen/dp_177"
                android:gravity="center"
                android:text="Clear"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="@dimen/dp_35"
                android:textColor="@color/white"
                app:background_normal="@color/colorFontA"
                app:corner_radius="@dimen/dp_26" />


        </androidx.constraintlayout.widget.ConstraintLayout>





        <include

            android:id="@+id/finishLay"
            layout="@layout/include_clear_finish"/>


    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>